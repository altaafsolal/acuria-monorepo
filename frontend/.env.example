# Frontend (Vite) environment variables.
#
# Only variables prefixed with VITE_ are exposed to the browser bundle, and they
# are inlined at BUILD TIME — after changing any of these you must rebuild
# (in dev, restart `npm run dev`; on Vercel, redeploy).
#
# In local dev you normally need NONE of these: the Vite dev server proxies /api
# and /api/ws to the backend on :3001 (see vite.config.ts), and the defaults below
# kick in. You mainly set these for a deployed build (see DEPLOYMENT.md).

# Base URL of the backend API, INCLUDING the /api suffix.
# Dev (default): unset → falls back to "/api" (proxied to localhost:3001).
# Prod (preferred, same origin on Vercel): /api
# Prod (absolute): https://app.acuria.com/api
VITE_API_URL=/api

# WebSocket URL for the super-admin realtime dashboard.
# Prefer leaving this UNSET in production when VITE_API_URL is an absolute URL —
# the client derives wss://<same-host>/api/ws so REST and WS never drift apart.
# Only set VITE_WS_URL to override (rare). A stale host here is the usual cause of
# "WebSocket connection failed" while the REST API still works.
VITE_WS_URL=

# Optional: URL of the DER template document surfaced on the KYC → DER page.
# Unset → the template link/preview is simply hidden. Not required to run the app.
VITE_DER_TEMPLATE_URL=
