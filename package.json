{
  "name": "acuria-platform",
  "private": true,
  "version": "0.1.0",
  "description": "Acuria Platform monorepo — React frontend and Express backend",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=backend\" \"npm run dev --workspace=frontend\"",
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:backend": "npm run dev --workspace=backend",
    "setup": "npm run setup --workspace=backend",
    "db:setup": "npm run setup --workspace=backend",
    "build": "npm run build --workspace=frontend",
    "start": "npm run start --workspace=backend",
    "test": "npm run test --workspace=backend && npm run test --workspace=frontend",
    "test:backend": "npm run test --workspace=backend",
    "test:frontend": "npm run test --workspace=frontend"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
