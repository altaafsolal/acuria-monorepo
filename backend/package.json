{
  "name": "acuria-backend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "setup": "tsx cli/setup.ts",
    "migrate:airtable": "tsx cli/migrate-airtable.ts",
    "provision:tenant-workspace": "tsx cli/provision-tenant-workspace.ts",
    "provision:tenant-tables": "tsx cli/provision-tenant-tables.ts",
    "provision:tenant": "tsx cli/provision-tenant-tables.ts",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "kill-port": "kill-port 3001"
  },
  "dependencies": {
    "axios": "^1.9.0",
    "tsx": "^4.22.4",
    "bcryptjs": "^3.0.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dayjs": "^1.11.21",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "form-data": "^4.0.6",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.2.0",
    "node-sp-auth": "^3.0.9",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.2.0",
    "@types/node": "^26.0.0",
    "@types/ws": "^8.18.1",
    "kill-port": "^2.0.1",
    "typescript": "^6.0.3"
  }
}
