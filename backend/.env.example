PORT=3001
NODE_ENV=development

JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

CORS_ORIGINS=http://localhost:4001

SUPER_ADMIN_EMAIL=admin@acuria.partners
SUPER_ADMIN_PASSWORD=admin123
SUPER_ADMIN_NAME=Super Admin

# ── Baserow (main database: users + tenants) ────────────────────────────────
# Docs: https://baserow.io/user-docs/personal-api-tokens
BASEROW_API_URL=https://api.baserow.io
BASEROW_MAIN_DATABASE_ID=473304

# 1) Database token — for the running app (read/write rows)
#    Workspace (top-left) → Settings → Database tokens → Create token +
#    Grant Create + Read + Update + Delete on your workspace/tables.
#    Header format: Authorization: Token YOUR_TOKEN
#    (BASEROW_MASTER_TOKEN is accepted as a fallback alias if this is unset.)
BASEROW_DATABASE_TOKEN=

# 2) Account login — for npm run setup and creating tenant databases (JWT)
#    Use your Baserow login email + password (username in the API is your email).
#    If your password contains # or $, wrap it in double quotes.
BASEROW_EMAIL=
BASEROW_PASSWORD=

# 3) Table IDs — printed after `npm run setup`, or from the table URL in Baserow
BASEROW_USERS_TABLE_ID=
BASEROW_TENANTS_TABLE_ID=

# 4) Workspace ID — the Baserow workspace new tenant databases are created in.
#    Required to provision a new tenant (creates that tenant's database + token).
BASEROW_WORKSPACE_ID=

# Frontend URL (used in password-set email links)
APP_URL=http://localhost:4001

# Make.com webhooks — KYC flows (7 scenarios, excluding auth emails below)
# Scénario 5 — DER → DocuSign (old: MAKE_WEBHOOK_DOCUSIGN, URL: 3fev0n42…)
MAKE_WEBHOOK_DER_DOCUSIGN=
# Scénario 6 — DER → Google Docs PDF → email (old: MAKE_WEBHOOK_DER, URL: 6cnprecw…)
MAKE_WEBHOOK_DER=
# Scénario 7 — LdM → Dropbox → DocuSign (old: MAKE_WEBHOOK_LDM, URL: u3btpbbe…)
MAKE_WEBHOOK_LDM=
# LdM preview — returns PDF blob (old: MAKE_WEBHOOK_PREVIEW, URL: cn4pcd3p…)
MAKE_WEBHOOK_PREVIEW=
# Envoi lien client (old: MAKE_WH4, URL: noydem1a…)
MAKE_WEBHOOK_FCC_SEND=
# FCC form data forwarded to Make on submission (old: MAKE_WEBHOOK_URL in DemoFinance form, URL: by7mjmgj…)
MAKE_WEBHOOK_FCC_SUBMIT=
# Send FCC PDF to DocuSign for signing (old: DOCUSIGN_WEBHOOK, URL: c7nl9jij…)
MAKE_WEBHOOK_FCC_DOCUSIGN=
# Note attachment → Make → SharePoint
MAKE_WEBHOOK_NOTE_UPLOAD=

# Make.com webhooks — auth emails
# Triggered when an admin creates/resets a user.
# Make receives: { email, name, set_password_link }
# → Send an email to `email` with a button pointing to `set_password_link`
MAKE_WEBHOOK_PASSWORD_SET=
# Triggered when a user requests "Forgot password".
# Make receives: { email, name, otp_code }
# → Send an email to `email` containing the 6-digit OTP code
MAKE_WEBHOOK_OTP=

# ── Google Docs template IDs (Drive) ────────────────────────────────────────
GOOGLE_DOC_DER_ID=
GOOGLE_DOC_LDM_PP_SANS=
GOOGLE_DOC_LDM_PP_AVEC=
GOOGLE_DOC_LDM_PM_SANS=
GOOGLE_DOC_LDM_PM_AVEC=

# ── FCC forms are now served internally at /fcc/pp.html and /fcc/pm.html ────
# APP_URL must be set correctly for the prefill links to work.

# ── Airtable migration (optional — only for npm run migrate:airtable) ────────
# One-time data import from Airtable. Leave unset for normal operation.
# The table names below have working defaults in code; override only if yours differ.
# AIRTABLE_PAT=
# AIRTABLE_BASE_ID=
# AIRTABLE_TABLE_CLIENTS=NM - Clients
# AIRTABLE_TABLE_RELATIONS=NM - Relation clients
# AIRTABLE_TABLE_KYC_DOCS=NM - Documents KYC
# AIRTABLE_TABLE_GESTIONNAIRES=tblatPVdokDBqRUjh
# AIRTABLE_TABLE_NOTES=tblHFssvCt0EMZfsa
# AIRTABLE_TABLE_TASKS=tblknqykhXNfQzT9P
# AIRTABLE_TABLE_FCC_CLIENTS=FCC_Clients

# ── SharePoint — document storage for note attachments ──────────────────────
# Site URL (no trailing slash) e.g. https://contoso.sharepoint.com/sites/acuria
SP_SITE_URL=
SP_USERNAME=
SP_PASSWORD=
# Folder path relative to the site (must already exist in SharePoint)
SP_FOLDER=Documents/Notes

# ── Per-tenant SharePoint OAuth (Microsoft Entra ID) ─────────────────────────
# Full setup walkthrough: docs/sharepoint-oauth-setup.md
#
# Public origin of THIS API including /api. The Microsoft redirect URI must reach
# the backend, not the SPA — so this is separate from APP_URL.
API_BASE_URL=http://localhost:3001/api
#
# Multitenant app registration (Entra ID → App registrations).
# "Supported account types" MUST be "Any Microsoft Entra ID tenant — Multitenant",
# otherwise only your own Microsoft org can ever connect.
AZURE_CLIENT_ID=
# Certificates & secrets → New client secret → copy the VALUE (not the Secret ID).
AZURE_CLIENT_SECRET=
# Must match a redirect URI registered on the app (platform type: Web).
# Defaults to ${API_BASE_URL}/oauth/sharepoint/callback if left blank.
AZURE_REDIRECT_URI=
#
# Encrypts each tenant's OAuth tokens at rest (AES-256-GCM). 64 hex chars.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Rotating this makes every stored token undecryptable — tenants must reconnect.
TOKEN_ENCRYPTION_KEY=

# ── Per-tenant email OAuth (Microsoft 365 Mail.Send + Gmail) ─────────────────
# Full setup walkthrough: docs/email-oauth-setup.md
#
# Microsoft 365 email reuses the SAME Azure app as SharePoint (AZURE_CLIENT_ID /
# AZURE_CLIENT_SECRET above) — you just add the delegated Mail.Send permission and
# register the email redirect URI below on that app. No separate Microsoft creds.
#
# Gmail needs a SEPARATE Google Cloud OAuth client (Google has no Azure-style
# multitenancy). Enable the Gmail API, request only the gmail.send scope.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
#
# BOTH providers redirect here after consent (provider carried in signed state).
# Register this exact URL on the Azure app AND the Google OAuth client.
# Defaults to ${API_BASE_URL}/oauth/email/callback if left blank.
EMAIL_REDIRECT_URI=

# ── Inbound webhooks from Make.com (shared secret) ───────────────────────────
# All Make scenarios that call back into the platform use this Authorization header value.
# In Make: HTTP module → Headers → Authorization: <value below>
# This also guards the SharePoint token broker:
#   GET /api/tenants/:tenantId/sharepoint/token
WEBHOOK_SECRET=

